# kaddy .gitignore
# Restored after an accidental PocketIDP overwrite (2026-07-15).

# --- Harness: local-only, never committed (see AGENTS.md) ---
.claude/
agent-context/

# --- Third-party reference material (kept locally, not vendored) ---
references/

# --- Secrets / local env ---
.envrc
*.env
!.envrc.example
# Pinned cluster tool/chart versions must be committed (E1e, REQ-E1e-S05-01)
!hack/cluster/versions.env
kube/
kubeconfig
*.kubeconfig

# --- OpenTofu / Terraform ---
.terraform/
.terraform.lock.hcl
# E1g: commit the gridscale stack lock files for reproducible provider pinning
# (multi-platform hashes) so CI/offline runs resolve the SAME provider build.
!stacks/gridscale/**/.terraform.lock.hcl
# E13: same reproducible-pinning intent for the Marketplace stacks + module.
!stacks/gridscale-marketplace/**/.terraform.lock.hcl
!modules/marketplace-template/.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
crash.*.log

# --- Task / tooling caches ---
.task/
.cache/

# --- Node / Slidev ---
node_modules/
slides/dist/
slides/.slidev/

# --- Python ---
__pycache__/
*.pyc
.venv/

# --- Evidence: generated run artifacts (keep README + templates) ---
evidence/runs/

# --- OS / editor ---
.DS_Store
.AppleDouble
.LSOverride
*.swp
*~

# Local cluster state (kubeconfig, generated certs) — never commit
.state/

# Un-ignore the committed harness charter (overrides global ~/.config/git/ignore)
!AGENTS.md
site/
