# Pinned versions for the E1e local kind substrate (REQ-E1e-S05-01).
# No floating tags anywhere — every chart/image is pinned to an exact version so the
# cluster is reproducible and the secure-install meta test (tests/meta/e1e-security.sh)
# stays green. Sourced by hack/cluster/*.sh.

# kind node image (kubernetes version). Kept in sync with hack/cluster/kind/cluster.yaml.
KIND_NODE_IMAGE="kindest/node:v1.33.1"

# kind cluster name (podman/docker provider). Fixed for idempotent bring-up.
CLUSTER_NAME="kaddy-dev"

# Cilium Helm chart (CNI + Gateway API + LB-IPAM/L2 + kube-proxy replacement).
CILIUM_VERSION="1.18.11"

# Gateway API standard-channel CRDs — applied BEFORE Cilium (REQ-E1e-S02-02).
GATEWAY_API_VERSION="v1.2.1"

# cert-manager Helm chart (REQ-E1e-S03-01) — pinned per spec.
CERT_MANAGER_VERSION="v1.18.2"

# Loopback-bound Gateway NodePorts (must match cluster.yaml extraPortMappings).
KIND_HOST_HTTP_PORT="30080"
KIND_HOST_HTTPS_PORT="30443"
