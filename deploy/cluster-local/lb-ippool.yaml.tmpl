# CiliumLoadBalancerIPPool — template rendered by hack/cluster/install-cilium.sh
# (REQ-E1e-S02-03). The range is carved from the ACTUAL docker/podman `kind`
# bridge subnet at bring-up time (NOT the driving-range 192.168.100.x range),
# because the kind network CIDR differs between docker and rootless podman and
# does not exist until the cluster is created.
#
# __LB_START__ / __LB_STOP__ are substituted with a high slice of the kind subnet
# (e.g. 10.89.0.200-10.89.0.250) so it cannot collide with node IPs.
#
# macOS note: this subnet is not host-routable; the assigned LB IP is asserted
# present in status.addresses only — never curled from the host.
apiVersion: cilium.io/v2
kind: CiliumLoadBalancerIPPool
metadata:
  name: kaddy-local-pool
spec:
  blocks:
    - start: "__LB_START__"
      stop: "__LB_STOP__"
